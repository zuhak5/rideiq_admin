# Web app environment variables (Vite)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Canonical client key name (recommended)
# - May be a modern publishable key (sb_publishable_...) or a legacy anon key (JWT)
VITE_SUPABASE_ANON_KEY=<your-publishable-or-anon-key>

# Compatibility alias (accepted but discouraged for new deployments)
# VITE_SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>

# Pricing entrypoint (Edge Function).
# Optional override for the Edge Function name (default: fare-engine).
VITE_FARE_ENGINE_FUNCTION_NAME=fare-engine

# Google Maps
# The web app fetches a public Maps browser key at runtime from the `maps-config` Edge Function.
# Do NOT embed Maps keys in Vite env vars.
