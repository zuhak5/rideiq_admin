# Supabase Edge Functions environment variables
# Local development: `supabase functions serve` loads from this `.env`.
# Production (deployed): configure in Supabase Dashboard -> Functions -> Environment variables.

# Required
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Canonical key names (recommended)
# - SUPABASE_ANON_KEY: client key (may be sb_publishable_... or legacy anon JWT)
# - SUPABASE_SERVICE_ROLE_KEY: server key (may be sb_secret_... or legacy service_role JWT)
SUPABASE_ANON_KEY=<your-publishable-or-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-secret-or-service-role-key>

# Compatibility aliases (accepted but discouraged for new deployments)
# SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>
# SUPABASE_SECRET_KEY=<your-secret-key>

# Shared secrets
# Used to protect verify_jwt=false cron/maintenance endpoints.
CRON_SECRET=<random-long-secret>

# Anonymous maps telemetry (render success/failure)
# HMAC secret used to mint short-lived tokens returned from maps-config-v2.
# This allows public pages to log render events without requiring end-user auth.
MAPS_TELEMETRY_HMAC_SECRET=<random-long-secret>

# Fraud/abuse detection (Session 09)
# HMAC key used to compute a privacy-aware device fingerprint hash.
FRAUD_FINGERPRINT_HMAC_KEY=<random-long-secret>

# Webhook job queue tuning
WEBHOOK_JOB_BATCH_LIMIT=10
WEBHOOK_JOB_LOCK_SECONDS=300
WEBHOOK_JOB_MAX_ATTEMPTS=10
WEBHOOK_RETRY_BASE_SECONDS=30
WEBHOOK_RETRY_MAX_SECONDS=3600

# Optional webhook replay guard (only enforced if provider includes a timestamp header)
WEBHOOK_MAX_AGE_SECONDS=300

# Provider webhook verification
# QiCard
QICARD_WEBHOOK_SECRET=<qicard-topup-webhook-secret>
QICARD_PAYOUT_WEBHOOK_SECRET=<qicard-payout-webhook-secret>
QICARD_ALLOW_INSECURE_WEBHOOKS=false

# AsiaPay / PayDollar
ASIAPAY_SECURE_HASH_SECRET=<asiapay-topup-securehash-secret>
ASIAPAY_PAYOUT_SECURE_HASH_SECRET=<asiapay-payout-securehash-secret>
ASIAPAY_ALLOW_INSECURE_WEBHOOKS=false

# Route engine base URL (OSRM-compatible)
# For production: self-host OSRM for Iraq (OSM extract) and point to it.
ROUTING_OSRM_BASE_URL=https://router.project-osrm.org

# Google Maps Platform
# Client key (public) - must be restricted by HTTP referrers / bundle id / package name and by API allowlist.
MAPS_CLIENT_KEY=
# Server key (secret) - restrict by IP (or trusted egress) and by API allowlist.
MAPS_SERVER_KEY=
# Optional Map ID for styling
MAPS_MAP_ID=

# Mapbox
# Public access token (use URL allowlist / scopes).
MAPBOX_PUBLIC_TOKEN=

# HERE
# API key (treat as secret; restrict by referrer where supported).
HERE_API_KEY=

# Thunderforest
# API key (treat as secret; restrict by referrer/IP if available).
THUNDERFOREST_API_KEY=
