# RideIQ Admin Dashboard environment variables (Next.js)
#
# Copy to: admin_dashboard/.env.local

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase publishable/anon key (safe to expose to the browser).
# Do NOT use sb_secret_* keys or legacy service_role JWTs here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-publishable-or-anon-key>

# Optional: label to display/use for environment-specific behavior.
# NEXT_PUBLIC_APP_ENV=local

# Optional: allowed origins for Next.js Server Actions.
# Comma-separated list (no scheme), e.g.:
# ADMIN_ALLOWED_ORIGINS=admin.example.com,*.example.com

